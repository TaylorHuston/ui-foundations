{
  "name": "ui-foundations",
  "version": "0.0.0",
  "private": true,
  "description": "A dependency-free, copyable CSS starting point for authored application interfaces.",
  "type": "module",
  "files": [
    "src"
  ],
  "exports": {
    ".": "./src/index.css",
    "./accessibility.css": "./src/accessibility.css",
    "./base.css": "./src/base.css",
    "./reset.css": "./src/reset.css",
    "./tokens.css": "./src/tokens.css"
  },
  "scripts": {
    "check": "node scripts/check.mjs",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6008 --no-open",
    "build:storybook": "storybook build",
    "compare:capture": "node scripts/capture-comparison.mjs",
    "check:all": "npm run check && npm run typecheck && npm run build:storybook"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
