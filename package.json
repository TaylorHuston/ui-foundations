{
  "name": "ui-foundations",
  "version": "0.1.0",
  "private": true,
  "description": "Copyable CSS and tested React references for authored application interfaces.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TaylorHuston/ui-foundations.git"
  },
  "homepage": "https://github.com/TaylorHuston/ui-foundations#readme",
  "bugs": "https://github.com/TaylorHuston/ui-foundations/issues",
  "type": "module",
  "files": [
    "src"
  ],
  "exports": {
    ".": "./src/index.css",
    "./fonts.css": "./src/styles/fonts.css",
    "./global.css": "./src/styles/global.css",
    "./primitives.css": "./src/styles/primitives.css",
    "./tokens.css": "./src/styles/tokens.css"
  },
  "scripts": {
    "check": "node scripts/check.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "storybook": "storybook dev -p 6008 --no-open",
    "build:storybook": "storybook build",
    "compare:capture": "node scripts/capture-comparison.mjs",
    "check:all": "npm run check && npm run typecheck && npm test && npm run build:storybook"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.24.0",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0"
  }
}
