{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist/types",
    "rootDir": "src"
  },
  "include": [
    "src/index.ts",
    "src/theme-profiles.ts",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/patterns/**/*.ts",
    "src/patterns/**/*.tsx"
  ],
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test/**"
  ]
}
