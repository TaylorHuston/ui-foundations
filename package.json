{
  "name": "@taylorhuston/ui-foundations",
  "version": "0.1.0",
  "private": true,
  "description": "Typed React interface foundations with semantic CSS and app-owned override seams.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TaylorHuston/ui-foundations.git"
  },
  "homepage": "https://github.com/TaylorHuston/ui-foundations#readme",
  "bugs": "https://github.com/TaylorHuston/ui-foundations/issues",
  "type": "module",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/types/components/index.d.ts",
      "import": "./dist/components.js"
    },
    "./patterns": {
      "types": "./dist/types/patterns/index.d.ts",
      "import": "./dist/patterns.js"
    },
    "./theme-profiles": {
      "types": "./dist/types/theme-profiles.d.ts",
      "import": "./dist/theme-profiles.js"
    },
    "./styles.css": "./dist/foundation.css",
    "./components.css": "./dist/components.css",
    "./fonts.css": "./dist/fonts.css",
    "./global.css": "./dist/global.css",
    "./primitives.css": "./dist/primitives.css",
    "./tokens.css": "./dist/tokens.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:library": "node scripts/build-library.mjs",
    "check": "node scripts/check.mjs",
    "check:package": "npm run build:library && node scripts/verify-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "storybook": "storybook dev -p 6008 --no-open",
    "build:storybook": "storybook build",
    "compare:capture": "node scripts/capture-comparison.mjs",
    "check:all": "npm run check && npm run typecheck && npm test && npm run build:library && node scripts/verify-package.mjs && npm run build:storybook",
    "prepack": "npm run build:library"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "lucide-react": "^1.24.0"
  }
}
